APP_NAME=Themis API
APP_VERSION=0.1.0
ENVIRONMENT=local
ENABLE_DOCS=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL=postgresql+psycopg://themis:themis@db:5432/themis
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://themis:themis@rabbitmq:5672//

POSTGRES_DB=themis
POSTGRES_USER=themis
POSTGRES_PASSWORD=themis

RABBITMQ_DEFAULT_USER=themis
RABBITMQ_DEFAULT_PASS=themis

MINIO_ROOT_USER=themis
MINIO_ROOT_PASSWORD=themis-local-password
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=themis-documents
OBJECT_STORAGE_REGION=ap-south-1

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URL=
AUTH_TOKEN_USE=id
AUTH_ROLE_CLAIM=custom:role
AUTH_ADMIN_GROUP=admin
AUTH_LAWYER_GROUP=lawyer
LOCAL_AUTH_ENABLED=true
